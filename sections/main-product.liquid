<div class="B__container">
  <div class="single-product-container">
    <div class="product-section-inner">
      
      <!-- Left Media Column -->
      <div class="product-image-wrapper">
        <div class="product-image-container">
          {%- if product.images.size > 1 -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" 
                 alt="{{ product.title | escape }}" 
                 class="product-image-primary"
                 width="600"
                 height="600">
            <img src="{{ product.images[1] | image_url: width: 1200 }}" 
                 alt="{{ product.title | escape }}" 
                 class="product-image-secondary"
                 width="600"
                 height="600">
          {%- else -%}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" 
                 alt="{{ product.title | escape }}" 
                 class="product-image-primary"
                 width="600"
                 height="600">
          {%- endif -%}
        </div>
      </div>

      <!-- Right Form & Details Column -->
      <div class="product-details-wrapper">
        <div class="product-header-info">
          <h1 class="product-title-heading">{{ product.title | upcase }}</h1>
          <div class="product-price-tag">{{ product.selected_or_first_available_variant.price | money }}</div>
        </div>

        {%- form 'product', product, class: 'product-ajax-form', data-product-id: product.id -%}
          
          <!-- Custom Transparent Select Wrapper -->
          {%- if product.variants.size > 0 -%}
            <div class="PI__select_wrap">
              <div class="PI__placeholder">
                <span class="PI__placeholder-text">CHOOSE SIZE</span>
                <select name="id" class="PI__select" id="VariantSelect-{{ product.id }}">
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}" 
                            data-available="{{ variant.available }}" 
                            data-price="{{ variant.price }}" 
                            data-price-formatted="{{ variant.price | money }}"
                            {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                      {{ variant.title | escape }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endif -%}

          <!-- Add to Cart Submit button -->
          <div class="add-to-cart-action-group">
            <button type="submit" name="add" class="add-to-cart-submit-btn" 
                    {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {%- if product.selected_or_first_available_variant.available -%}
                ADD TO CART
              {%- else -%}
                SOLD OUT
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}

        <!-- Expandable details disclosure -->
        {%- if product.description != blank -%}
          <div class="product-desc-accordion">
            <button type="button" class="desc-accordion-toggle">DETAILS</button>
            <div class="desc-accordion-content">
              <div class="desc-text">{{ product.description }}</div>
            </div>
          </div>
        {%- endif -%}

        <!-- Expandable size chart disclosure -->
        {%- assign product_title_lower = product.title | downcase -%}
        {%- if product.handle contains 'hoodie' or product_title_lower contains 'hoodie' -%}
          <div class="product-desc-accordion" style="margin-top: 0; border-top: none;">
            <button type="button" class="desc-accordion-toggle">SIZE CHART</button>
            <div class="desc-accordion-content">
              <div class="desc-text">
                
                <div class="size-chart-toggle-wrapper">
                  <button type="button" class="unit-toggle-btn active" data-unit="cm">CM</button>
                  <button type="button" class="unit-toggle-btn" data-unit="inch">INCH</button>
                </div>

                <div class="size-chart-table-wrapper">
                  <!-- CM Table -->
                  <table class="size-chart-table unit-cm">
                    <thead>
                      <tr>
                        <th>Part</th>
                        <th>S</th>
                        <th>M</th>
                        <th>L</th>
                        <th>XL</th>
                        <th>2XL</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>Chest</td>
                        <td>64</td>
                        <td>66</td>
                        <td>68</td>
                        <td>70</td>
                        <td>72</td>
                      </tr>
                      <tr>
                        <td>Neck Width</td>
                        <td>28</td>
                        <td>29</td>
                        <td>30</td>
                        <td>31</td>
                        <td>32</td>
                      </tr>
                      <tr>
                        <td>Sleeve Shoulder Opening</td>
                        <td>26</td>
                        <td>27</td>
                        <td>28</td>
                        <td>29</td>
                        <td>30</td>
                      </tr>
                      <tr>
                        <td>Length</td>
                        <td>62</td>
                        <td>64</td>
                        <td>66</td>
                        <td>68</td>
                        <td>70</td>
                      </tr>
                      <tr>
                        <td>Sleeve Length</td>
                        <td>52</td>
                        <td>53</td>
                        <td>54</td>
                        <td>55</td>
                        <td>56</td>
                      </tr>
                      <tr>
                        <td>Drop Shoulder</td>
                        <td>26.8</td>
                        <td>27.4</td>
                        <td>28</td>
                        <td>28.6</td>
                        <td>29.2</td>
                      </tr>
                      <tr>
                        <td>Hood Length</td>
                        <td>37.5</td>
                        <td>38.5</td>
                        <td>39.5</td>
                        <td>40.5</td>
                        <td>41.5</td>
                      </tr>
                      <tr>
                        <td>Hood Width</td>
                        <td>29.9</td>
                        <td>30.7</td>
                        <td>31.5</td>
                        <td>32.3</td>
                        <td>33.1</td>
                      </tr>
                    </tbody>
                  </table>

                  <!-- INCH Table -->
                  <table class="size-chart-table unit-inch" style="display: none;">
                    <thead>
                      <tr>
                        <th>Part</th>
                        <th>S</th>
                        <th>M</th>
                        <th>L</th>
                        <th>XL</th>
                        <th>2XL</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>Chest</td>
                        <td>25.2</td>
                        <td>26.0</td>
                        <td>26.8</td>
                        <td>27.6</td>
                        <td>28.3</td>
                      </tr>
                      <tr>
                        <td>Neck Width</td>
                        <td>11.0</td>
                        <td>11.4</td>
                        <td>11.8</td>
                        <td>12.2</td>
                        <td>12.6</td>
                      </tr>
                      <tr>
                        <td>Sleeve Shoulder Opening</td>
                        <td>10.2</td>
                        <td>10.6</td>
                        <td>11.0</td>
                        <td>11.4</td>
                        <td>11.8</td>
                      </tr>
                      <tr>
                        <td>Length</td>
                        <td>24.4</td>
                        <td>25.2</td>
                        <td>26.0</td>
                        <td>26.8</td>
                        <td>27.6</td>
                      </tr>
                      <tr>
                        <td>Sleeve Length</td>
                        <td>20.5</td>
                        <td>20.9</td>
                        <td>21.3</td>
                        <td>21.7</td>
                        <td>22.0</td>
                      </tr>
                      <tr>
                        <td>Drop Shoulder</td>
                        <td>10.6</td>
                        <td>10.8</td>
                        <td>11.0</td>
                        <td>11.3</td>
                        <td>11.5</td>
                      </tr>
                      <tr>
                        <td>Hood Length</td>
                        <td>14.8</td>
                        <td>15.2</td>
                        <td>15.6</td>
                        <td>15.9</td>
                        <td>16.3</td>
                      </tr>
                      <tr>
                        <td>Hood Width</td>
                        <td>11.8</td>
                        <td>12.1</td>
                        <td>12.4</td>
                        <td>12.7</td>
                        <td>13.0</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Page Content",
  "settings": []
}
{% endschema %}
