<header class="site-header" role="banner">
  <div class="header-container">
    <div class="header-left-empty"></div> <!-- Left column spacer to push logo center -->

    <div class="header-center-logo">
      <a href="{{ routes.root_url }}" class="header-logo-link">
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="header-logo-default" width="380" height="auto">
      </a>
    </div>

    <div class="header-right">
      <button class="header-cart-toggle" id="CartToggle" aria-haspopup="dialog" aria-expanded="false">
        CART (<span class="cart-count">{{ cart.item_count }}</span>)
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
