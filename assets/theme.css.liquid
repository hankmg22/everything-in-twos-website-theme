/* Travis Scott Typography CDN Imports */
@font-face {
  font-family: 'News Gothic Condensed';
  src: url("https://shop.travisscott.com/cdn/shop/t/21/assets/NewsGothicCondensed.woff2") format("woff2");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: "souvenir";
  src: url("https://shop.travisscott.com/cdn/shop/t/21/assets/souvenir_bold-webfont.woff2") format("woff2");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}

:root {
  --color-bg: {{ settings.color_bg | default: '#ffffff' }};
  --color-primary: {{ settings.color_text | default: '#666666' }};
  --color-accent: {{ settings.color_accent | default: '#39FF14' }};
  --color-accent-dim: rgba(57, 255, 20, 0.15);
  
  --font-heading: 'souvenir', 'Playfair Display', Georgia, serif;
  --font-body: 'News Gothic Condensed', 'Helvetica Neue', Arial, sans-serif;
  
  --header-height: 80px;
}

/* Base resets matching scraped theme */
* {
  box-sizing: border-box;
  font-weight: 400;
  letter-spacing: .08px;
  margin: 0;
  padding: 0;
}



html, body {
  width: 100%;
  height: 100%;
}

body {
  background-color: var(--color-bg);
  color: var(--color-primary);
  font-family: var(--font-body);
  font-size: 15px;
  text-transform: uppercase;
  -webkit-font-smoothing: antialiased;
  scroll-behavior: smooth;
  overflow-x: hidden;
}

a {
  color: var(--color-primary);
  text-decoration: none;
  transition: color 0.2s ease;
}
a:hover {
  color: var(--color-accent);
}

.visually-hidden {
  position: absolute !important;
  overflow: hidden;
  width: 1px;
  height: 1px;
  margin: -1px;
  padding: 0;
  border: 0;
  clip: rect(0 0 0 0);
}

/* Scrollbar styling */
::-webkit-scrollbar {
  width: 5px;
  height: 5px;
}
::-webkit-scrollbar-track {
  background: var(--color-bg);
}
::-webkit-scrollbar-thumb {
  background: var(--color-primary);
}
::-webkit-scrollbar-thumb:hover {
  background: var(--color-accent);
}

/* Floating transparent header with mix-blend-mode difference */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: var(--header-height);
  z-index: 1000;
  background-color: transparent;
  mix-blend-mode: difference;
  color: #fff; /* White allows the difference mode to invert properly */
  pointer-events: none;
}

.header-container {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 100%;
  padding: 0 5%;
  max-width: 2200px;
  margin: 0 auto;
}

.header-left-empty,
.header-center-logo,
.header-right {
  pointer-events: auto;
}

.header-left-empty {
  /* Empty column block to balance grid layout */
}

.header-center-logo {
  display: flex;
  justify-content: center;
}

.header-right {
  display: flex;
  justify-content: flex-end;
}

.header-logo-default {
  max-width: 100%;
  max-height: 65px;
  width: auto;
  height: auto !important;
  filter: invert(1);
  transition: transform 0.2s ease;
}
.header-logo-default:hover {
  transform: scale(1.02);
}

@media(max-width: 768px) {
  .header-logo-default {
    max-height: 45px;
  }
}

.header-cart-toggle {
  background: none;
  border: none;
  color: inherit;
  font-family: inherit;
  font-size: 15px;
  text-transform: uppercase;
  cursor: pointer;
  padding: 10px 0;
  letter-spacing: 0.1em;
}

/* Page Layout Wrap matching Cactus Jack */
.Wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.B__container {
  margin: 0 auto;
  width: 100%;
  position: relative;
  padding-top: var(--header-height);
  flex-grow: 1;
}

/* Product catalog grid (5 columns on desktop) */
.ProductGrid {
  position: relative;
  text-align: center;
  width: 100%;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin: 40px auto 100px auto;
  padding: 0 20px;
  max-width: 2200px;
  gap: 30px 1%;
}

.ProductGridItem {
  opacity: 1;
  cursor: pointer !important;
  vertical-align: bottom;
  margin-bottom: 45px;
  line-height: 1.3;
  display: inline-block;
  position: relative;
  width: 19%; /* 5 columns grid layout */
}

@media(max-width: 1100px) {
  .ProductGridItem {
    width: 31%; /* 3 columns layout */
  }
}

@media(max-width: 768px) {
  .ProductGridItem {
    width: 48%; /* 2 columns layout */
  }
}

@media(max-width: 500px) {
  .ProductGridItem {
    width: 100% !important; /* 1 column layout on small mobile */
    margin-bottom: 60px;
    padding: 0 10px;
  }
}

/* Product grid item image hover swap */
.PGI__img_wrap {
  display: block;
  position: relative;
  width: 100%;
  margin: 0 auto 15px auto;
  padding-top: 100%; /* forces square aspect ratio */
  overflow: hidden;
  background-color: #fafafa;
  border-radius: 4px;
}

.PGI__img, .PGI__img_2 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.PGI__img_2 {
  opacity: 0;
}

.ProductGridItem:hover .PGI__img {
  opacity: 0;
}

.ProductGridItem:hover .PGI__img_2 {
  opacity: 1;
}

.PGI__title {
  font-size: 15px;
  line-height: 1.4;
  margin: 0 auto 5px auto;
  color: var(--color-primary);
  max-width: 90%;
}

.PGI__price {
  font-size: 15px;
  color: var(--color-primary);
  letter-spacing: .04em;
}

.PGI__sold_out {
  color: #f07223;
}

/* Single Product Detail Page styled like Cactus Jack */
.single-product-container {
  max-width: 1200px;
  margin: 40px auto 100px auto;
  padding: 0 20px;
}

.product-section-inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 8%;
  align-items: flex-start;
}

@media(max-width: 768px) {
  .product-section-inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}

.product-image-wrapper {
  width: 100%;
}

.product-image-container {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background-color: #fafafa;
  border-radius: 6px;
  overflow: hidden;
}

.product-image-primary, .product-image-secondary {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.product-image-secondary {
  opacity: 0;
}

.product-image-container:hover .product-image-primary {
  opacity: 0;
}
.product-image-container:hover .product-image-secondary {
  opacity: 1;
}

.product-details-wrapper {
  padding-top: 20px;
  text-align: center;
}

.product-header-info {
  margin-bottom: 25px;
}

.product-title-heading {
  font-family: var(--font-heading);
  font-size: 24px;
  font-weight: normal;
  line-height: 1.2;
  margin-bottom: 8px;
  color: var(--color-primary);
  letter-spacing: -0.01em;
}

.product-price-tag {
  font-size: 16px;
  letter-spacing: 0.05em;
  color: var(--color-primary);
}

/* Custom transparent dropdown overlay */
.PI__select_wrap {
  margin: 15px auto 25px auto;
  position: relative;
  display: inline-block;
  text-align: center;
}

.PI__placeholder {
  position: relative;
  padding: 6px 30px 6px 10px;
  border-bottom: 1px solid var(--color-primary);
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--color-primary);
  text-transform: uppercase;
  cursor: pointer;
  display: inline-block;
  min-width: 140px;
  text-align: center;
}

.PI__placeholder:after {
  content: "";
  position: absolute;
  right: 8px;
  top: 55%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 5px 4.5px 0 4.5px;
  border-color: var(--color-primary) transparent transparent transparent;
  pointer-events: none;
}

select.PI__select {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: pointer;
  z-index: 10;
}

/* Add to Cart submit styling */
.add-to-cart-action-group {
  margin: 20px auto;
  max-width: 320px;
}

.add-to-cart-submit-btn {
  width: 100%;
  padding: 12px 24px;
  background-color: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  font-family: var(--font-body);
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: all 0.25s ease;
  border-radius: 0;
}

.add-to-cart-submit-btn:hover {
  background-color: var(--color-primary);
  color: var(--color-bg);
}

.add-to-cart-submit-btn:disabled {
  background-color: transparent;
  color: #ccc;
  border-color: #eee;
  cursor: not-allowed;
}

/* Accordion details */
.product-desc-accordion {
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  padding: 12px 0;
  max-width: 500px;
  margin: 30px auto 0 auto;
}

.desc-accordion-toggle {
  width: 100%;
  text-align: center;
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: 15px;
  text-transform: uppercase;
  cursor: pointer;
  display: flex;
  justify-content: center;
  gap: 15px;
  align-items: center;
}

.desc-accordion-toggle::after {
  content: '+';
  font-size: 16px;
  font-weight: 300;
  transition: transform 0.2s ease;
}

.product-desc-accordion.active .desc-accordion-toggle::after {
  transform: rotate(45deg);
}

.desc-accordion-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.desc-text {
  padding-top: 12px;
  font-size: 14px;
  color: var(--color-primary);
  line-height: 1.6;
  text-align: center;
  max-width: 420px;
  margin: 0 auto;
}

/* Slide-out AJAX Cart Drawer */
.cart-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 2000;
  visibility: hidden;
  transition: visibility 0.4s;
}

.cart-drawer.active {
  visibility: visible;
}

.cart-drawer-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.2);
  opacity: 0;
  transition: opacity 0.4s ease;
}

.cart-drawer.active .cart-drawer-backdrop {
  opacity: 1;
}

.cart-drawer-inner {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  max-width: 440px;
  height: 100%;
  background-color: var(--color-bg);
  box-shadow: -5px 0 25px rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  border-left: 1px solid var(--color-primary);
}

.cart-drawer.active .cart-drawer-inner {
  transform: translateX(0);
}

.cart-drawer-header {
  padding: 25px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.cart-drawer-title {
  font-size: 16px;
  letter-spacing: 0.05em;
}

.cart-drawer-close-btn {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: var(--color-primary);
  line-height: 1;
  transition: transform 0.2s ease;
}
.cart-drawer-close-btn:hover {
  transform: scale(1.1);
  color: var(--color-accent);
}

.cart-drawer-content {
  flex-grow: 1;
  overflow-y: auto;
  padding: 25px;
}

.cart-drawer-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
  gap: 15px;
}

.cart-drawer-continue-shopping-btn {
  font-size: 14px;
  border-bottom: 1px solid var(--color-primary);
  padding-bottom: 2px;
}

.cart-drawer-item {
  display: grid;
  grid-template-columns: 70px 1fr;
  gap: 15px;
  padding-bottom: 20px;
  margin-bottom: 20px;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.cart-drawer-item-img {
  width: 70px;
  height: 70px;
  object-fit: contain;
  background-color: #fafafa;
  border-radius: 4px;
}

.cart-drawer-item-details-col {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cart-drawer-item-title {
  font-size: 14px;
  line-height: 1.2;
}

.cart-drawer-item-variant {
  font-size: 13px;
  color: #999;
}

.cart-drawer-item-price-tag {
  font-size: 14px;
}

.cart-drawer-item-qty-selector {
  display: inline-flex;
  border: 1px solid rgba(0, 0, 0, 0.15);
  margin-top: 6px;
  width: 90px;
}

.qty-adjust-btn {
  background: none;
  border: none;
  width: 28px;
  height: 28px;
  cursor: pointer;
  font-size: 14px;
  color: var(--color-primary);
}
.qty-adjust-btn:hover {
  background-color: #f9f9f9;
  color: var(--color-accent);
}

.qty-adjust-input {
  width: 34px;
  height: 28px;
  border: none;
  border-left: 1px solid rgba(0, 0, 0, 0.15);
  border-right: 1px solid rgba(0, 0, 0, 0.15);
  text-align: center;
  font-family: inherit;
  font-size: 14px;
}

.cart-drawer-item-remove-link {
  background: none;
  border: none;
  color: #999;
  font-family: inherit;
  font-size: 12px;
  cursor: pointer;
  align-self: flex-start;
  margin-top: 6px;
  border-bottom: 1px solid transparent;
  transition: all 0.2s ease;
}
.cart-drawer-item-remove-link:hover {
  color: #ff3333;
  border-color: #ff3333;
}

.cart-drawer-checkout-footer {
  padding: 25px;
  border-top: 1px solid rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.cart-drawer-subtotal-summary {
  display: flex;
  justify-content: space-between;
  font-size: 15px;
}

.cart-drawer-checkout-disclaimer {
  font-size: 12px;
  color: #999;
  line-height: 1.3;
}

.cart-drawer-checkout-submit-btn {
  width: 100%;
  padding: 15px;
  background-color: var(--color-primary);
  color: var(--color-bg);
  border: 1px solid var(--color-primary);
  font-family: var(--font-body);
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: all 0.25s ease;
}
.cart-drawer-checkout-submit-btn:hover {
  background-color: transparent;
  color: var(--color-primary);
}

/* Minimalist footer styling */
.site-footer {
  padding: 60px 5% 40px 5%;
  border-top: 1px solid rgba(0, 0, 0, 0.05);
  background-color: var(--color-bg);
}

.footer-container {
  max-width: 2200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  gap: 5%;
  align-items: flex-start;
}

@media(max-width: 1024px) {
  .footer-container {
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .footer-nav-and-info {
    grid-column: span 2;
  }
}

@media(max-width: 768px) {
  .footer-container {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .footer-nav-and-info {
    grid-column: span 1;
  }
}

.footer-newsletter {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.newsletter-title {
  font-size: 15px;
  letter-spacing: 0.05em;
}

.newsletter-input-group {
  display: flex;
  border-bottom: 1px solid var(--color-primary);
  max-width: 400px;
}

.newsletter-email {
  flex-grow: 1;
  background: none;
  border: none;
  padding: 10px 0;
  font-family: inherit;
  font-size: 14px;
  color: var(--color-primary);
  text-transform: uppercase;
}
.newsletter-email:focus {
  outline: none;
}

.newsletter-submit-btn {
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: 14px;
  padding: 10px 12px;
  cursor: pointer;
  text-transform: uppercase;
}
.newsletter-submit-btn:hover {
  color: var(--color-accent);
}

.newsletter-success {
  font-size: 13px;
  color: green;
}

.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.footer-contact-title {
  font-size: 15px;
  letter-spacing: 0.05em;
}

.footer-contact-form {
  display: flex;
  flex-direction: column;
  gap: 15px;
  max-width: 400px;
}

.contact-fields {
  display: flex;
  gap: 15px;
}

.contact-fields input {
  flex: 1;
  background: none;
  border: none;
  border-bottom: 1px solid var(--color-primary);
  padding: 10px 0;
  font-family: inherit;
  font-size: 14px;
  color: var(--color-primary);
  text-transform: uppercase;
}
.contact-fields input:focus {
  outline: none;
  border-bottom-color: var(--color-accent);
}

.contact-message-group {
  display: flex;
  border-bottom: 1px solid var(--color-primary);
}

.contact-message-group textarea {
  flex-grow: 1;
  background: none;
  border: none;
  padding: 10px 0;
  font-family: inherit;
  font-size: 14px;
  color: var(--color-primary);
  text-transform: uppercase;
  resize: none;
}
.contact-message-group textarea:focus {
  outline: none;
}

.contact-submit-btn {
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: 14px;
  padding: 10px 12px;
  cursor: pointer;
  text-transform: uppercase;
  align-self: flex-end;
}
.contact-submit-btn:hover {
  color: var(--color-accent);
}

.contact-success {
  font-size: 13px;
  color: green;
}

.footer-nav-and-info {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.footer-links {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px 25px;
  font-size: 14px;
  letter-spacing: 0.05em;
}

.footer-links a:hover {
  color: var(--color-accent);
}

.footer-copyright {
  font-size: 13px;
  color: #999;
  line-height: 1.6;
}

.footer-easter-egg {
  font-size: 11px;
  color: #ccc;
}

.footer-socials {
  display: flex;
  gap: 25px;
  font-size: 14px;
}

.social-link:hover {
  color: var(--color-accent);
}

/* Page Fallbacks */
.cart-page-container,
.page-container,
.search-page-container,
.page-404-container {
  max-width: 900px;
  margin: 0 auto;
  padding: calc(var(--header-height) + 40px) 20px 100px 20px;
  min-height: 50vh;
}

.page-title, .cart-page-title, .search-page-title, .page-404-title {
  font-family: var(--font-heading);
  font-size: 28px;
  font-weight: normal;
  margin-bottom: 30px;
  text-align: center;
  color: var(--color-primary);
}

.page-content-wrapper {
  line-height: 1.7;
  font-size: 14px;
}
.page-content-wrapper p {
  margin-bottom: 15px;
}

.cart-page-items {
  display: flex;
  flex-direction: column;
  gap: 20px;
  max-width: 600px;
  margin: 0 auto 40px auto;
}

.cart-page-item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 25px;
  border-bottom: 1px solid rgba(0,0,0,0.05);
  padding-bottom: 20px;
}

.cart-page-footer {
  max-width: 600px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 15px;
}

.cart-subtotal {
  font-size: 15px;
}

.cart-checkout-btn {
  padding: 12px 24px;
  background-color: var(--color-primary);
  color: var(--color-bg);
  border: 1px solid var(--color-primary);
  font-family: var(--font-body);
  font-size: 15px;
  text-transform: uppercase;
  cursor: pointer;
}

/* 404 styles */
.page-404-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 10px;
}

.page-404-title {
  font-size: 72px;
  line-height: 1;
}

.page-404-home-link {
  margin-top: 15px;
  font-size: 14px;
  border-bottom: 1px solid var(--color-primary);
  padding-bottom: 2px;
}
